<%
  existing_barcodes = (results.dig('items') || []).map { |i| i['barcode'] }.compact
  new_containers = @aspace_containers.reject { |c| existing_barcodes.include?(c['barcode']) }
%>

<section id="add_items" class="subrecord-form-dummy">
  <h3><%= I18n.t("plugins.alma_integrations.add_items.heading") %></h3>
  <div class="subrecord-form-container">
    <% if @results['mms'].nil? %>
      <p><%= I18n.t("plugins.alma_integrations.errors.no_mms") %></p>
    <% elsif @holdings.nil? || @holdings['holdings'].nil? || @holdings['holdings'].empty? %>
      <p><%= I18n.t("plugins.alma_integrations.errors.no_holdings_for_items") %></p>
    <% elsif new_containers.empty? %>
      <p><%= I18n.t("plugins.alma_integrations.add_items.all_synced") %></p>
    <% else %>
      <%= form_tag({:controller => :alma_integrations, :action => :add_items}, {:class => "form-horizontal", :id => "add_items_form", :method => :post}) do |f| %>
        <input type="hidden" name="mms" value="<%= @results['mms'] %>"/>
        <input type="hidden" name="ref" value="<%= @results['ref'] %>"/>
        <div class="subrecord-form-fields">
          <div class="form-group required">
            <label class="control-label col-sm-2" for="holding_id"><%= I18n.t("plugins.alma_integrations.add_items.holding") %></label>
            <div class="col-sm-8">
              <select name="holding_id" class="form-control">
                <% @holdings['holdings'].each do |holding| %>
                  <option value="<%= holding['id'] %>"><%= holding['name'] %> (<%= holding['code'] %>)</option>
                <% end %>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="control-label col-sm-2"><%= I18n.t("plugins.alma_integrations.add_items.containers") %></label>
            <div class="col-sm-10">
              <table class="table table-striped table-bordered table-condensed table-hover">
                <thead>
                  <tr>
                    <th>
                      <input type="checkbox" id="select_all_containers" title="<%= I18n.t("plugins.alma_integrations.add_items.select_all") %>"/>
                    </th>
                    <th><%= I18n.t("plugins.alma_integrations.add_items.description") %></th>
                    <th><%= I18n.t("plugins.alma_integrations.add_items.barcode") %></th>
                    <th><%= I18n.t("plugins.alma_integrations.add_items.profile") %></th>
                  </tr>
                </thead>
                <tbody>
                  <% new_containers.each do |container| %>
                    <tr>
                      <td>
                        <input type="checkbox" name="container_refs[]" value="<%= container['ref'] %>" class="container-checkbox"/>
                      </td>
                      <td><%= container['description'] %></td>
                      <td><%= container['barcode'] %></td>
                      <td><%= container['profile'] %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="form-group">
            <div class="controls">
              <%= submit_tag I18n.t("plugins.alma_integrations.actions.add_items"), :class => "btn btn-primary pull-right", :id => "add_items_submit" %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</section>

<script>
  var selectAll = document.getElementById('select_all_containers');
  selectAll.addEventListener('change', function() {
    document.querySelectorAll('.container-checkbox').forEach(function(cb) {
      cb.checked = selectAll.checked;
    });
  });
</script>
